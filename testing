#!/usr/bin/env bash
set -eu

G='\033[0;32m'; R='\033[0;31m'; N='\033[0m'

ok(){ printf " [ ${G}ok${N} ]\n"; }
ko(){ printf " [ ${R}!!${N} ]\n"; exit 1; }

b(){ printf " * %s" "$1"; }
e(){ [ "$1" -eq 0 ] && ok || ko; }

q(){ "$@" >/dev/null 2>&1; }

D=$(mktemp -d -t spout.XXXXXX)
chmod 700 "$D"

export XDG_CONFIG_HOME="$D/cfg"
export XDG_CACHE_HOME="$D/cache"
export XDG_DATA_HOME="$D/data"

C="$XDG_CONFIG_HOME/spout"
B="./target/debug/spout"

x(){
    [ -n "${P:-}" ] && kill "$P" 2>/dev/null || true
    rm -rf "$D"
}
trap x EXIT INT TERM

m(){
    F="$D/p"
    cat > "$D/s.py" << 'EOF'
import http.server,json,sys
class H(http.server.BaseHTTPRequestHandler):
 def do_POST(self):
  self.send_response(200);self.end_headers()
  self.wfile.write(json.dumps({"imageUrl":"http://127.0.0.1/i.png","path":"/tmp/i.png"}).encode())
 def log_message(self,*a):pass
s=http.server.HTTPServer(("127.0.0.1",0),H)
with open(sys.argv[1],"w") as f:
 f.write(str(s.server_port));f.flush()
s.serve_forever()
EOF
    python3 "$D/s.py" "$F" >/dev/null 2>&1 &
    P=$!
    i=0
    while [ ! -s "$F" ]; do
        if ! kill -0 "$P" 2>/dev/null; then wait "$P" || true; return 1; fi
        [ "$i" -gt 50 ] && return 1
        sleep 0.1; i=$((i+1))
    done
    U="http://127.0.0.1:$(cat "$F")"
}

tb(){ q cargo build --quiet && [ -x "$B" ]; }

tc(){
    "$B" --help | grep -q Usage &&
    "$B" --version | grep -q v
}

tg(){
    q "$B" -g &&
    [ -f "$C/config.kdl" ] &&
    ! q "$B" -g &&
    q "$B" -G
}

tu(){
    mkdir -p "$C"
    cat > "$C/config.kdl" << EOF
default "m"
yolo true
profile "m" {
 url "$U"
 method "POST"
 format "binary"
 path "path"
}
EOF
    chmod 600 "$C/config.kdl"
    o=$(echo data | "$B" m 2>/dev/null) || return 1
    printf "%s" "$o" | grep -q "/tmp/i.png"
}

tf(){
    mkdir -p "$C"
    cat > "$C/config.kdl" << EOF
default "m"
yolo true
profile "m" {
 url "$U"
 method "POST"
 format "binary"
 path "nope"
}
EOF
    chmod 600 "$C/config.kdl"
    if echo data | "$B" m >/dev/null 2>&1; then return 1; fi
}

tp(){ q "$B" -p; }

echo " * Initializing test environment"

b "Starting mock server"; m; e $?
b "Building binary"; tb; e $?
b "Checking CLI flags"; tc; e $?
b "Config lifecycle"; tg; e $?
b "Upload flow"; tu; e $?
b "Invalid response path fails"; tf; e $?
b "Config parse check"; tp; e $?

echo " * All tests passed"
